        { "type": "sec", "section": "🛡️ Security & Secret Management", "hidden": false },
        { "type": "perf", "section": "⚡ Performance & Safety", "hidden": false },
        { "type": "docs", "section": "📚 Documentation", "hidden": false },
        { "type": "refactor", "section": "🔧 Refactoring & Architecture", "hidden": false },
        { "type": "test", "section": "🧪 Testing Infrastructure", "hidden": true },
        { "type": "ci", "section": "📦 Build & CI Workflows", "hidden": true },
        { "type": "chore", "section": "🧹 Maintenance", "hidden": true }
      ]
    }
  }
