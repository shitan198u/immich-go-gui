    ".": {
      "release-type": "python",
      "package-name": "immich-go-gui",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": false,
      "draft": false,
      "prerelease": false,
      "changelog-sections": [
        { "type": "feat", "section": "🚀 Features & UI Completeness", "hidden": false },
